{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-box">
        <h1>Sign in</h1>

        {% if error %}
            <div class="error-box">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" class="auth-form">
            <label>Email</label>
            <input type="email"
                   value="{{ last_username }}"
                   name="_username"
                   required
                   autofocus>

            <label>Password</label>
            <input type="password"
                   name="_password"
                   required>

            <input type="hidden"
                   name="_csrf_token"
                   value="{{ csrf_token('authenticate') }}">

            <button type="submit">Sign in</button>
        </form>
    </div>
</div>
{% endblock %}
