{% extends 'base.html.twig' %}

{% block body %}
<h1>Add Film</h1>

<form method="POST" enctype="multipart/form-data">
    <input type="text" name="title" placeholder="Title" required><br>
    <input type="text" name="genre" placeholder="Genre" required><br>
    <input type="text" name="director" placeholder="Director"><br>
    <textarea name="description" placeholder="Description"></textarea><br>
    <input type="number" name="rating" placeholder="Rating (0-100)"><br>

    <input type="file" name="poster" accept="image/*"><br><br>

    <button type="submit">Add Film</button>
</form>
{% endblock %}
